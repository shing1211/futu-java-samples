# Futu OpenD Connection
# For local single-node: use FUTU_OPEND_HOST/FUTU_OPEND_PORT
# For HA mode: use FUTU_OPEND_HOSTS (host:port:useRSA tuples, comma-separated)
# NOTE: Example00_ConnectHA can automatically try multiple hosts

# Single node (default)
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# HA mode: uncomment and set FUTU_OPEND_HOSTS instead
# FUTU_OPEND_HOSTS=172.18.208.88:11111:true,172.20.208.88:11111:true

# RSA encryption (set to true when using RSA auth)
FUTU_RSA_ENABLED=false
FUTU_RSA_KEY_PATH=/etc/futu/keys/private_key.pem

# Environment: dev | sim | prod
FUTU_ENV=dev