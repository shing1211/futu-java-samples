# FutuOpenD Connection Settings
# Default: 127.0.0.1:11111 (HK), 127.0.0.1:11112 (US), 127.0.0.1:11113 (CN)
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# RSA Encryption (optional)
# Set to true if your OpenD requires RSA encryption
FUTU_RSA_ENABLED=false
FUTU_RSA_KEY_PATH=/etc/futu/keys/private_key.pem

# Security Firm (optional)
# Examples: FUTU HK, MOOMOO US, MOOMOO SG, etc.
FUTU_SECURITY_FIRM=FUTU HK

# Trading Account (for trade-related examples)
FUTU_TRADE_PASSWORD=

# Environment: dev, prod
FUTU_ENV=dev
